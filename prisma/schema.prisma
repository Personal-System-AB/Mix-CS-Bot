// This is your Prisma schema file,
// learn more about it in the docs: https://pris.ly/d/prisma-schema

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "sqlite"
  url      = env("DATABASE_URL")
}

model User {
  id        String   @id @default(cuid())
  discordId String   @unique
  steamNick String?
  elo       Int      @default(1)
  wins      Int      @default(0)
  losses    Int      @default(0)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  queueEntries QueueEntry[]
  matchTeams   MatchTeam[]
}

model Queue {
  id        String   @id @default(cuid())
  guildId   String
  channelId String
  messageId String?
  isActive  Boolean  @default(true)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  entries QueueEntry[]
  matches Match[]

  @@unique([guildId, channelId])
}

model QueueEntry {
  id       String   @id @default(cuid())
  queueId  String
  userId   String
  joinedAt DateTime @default(now())

  queue Queue @relation(fields: [queueId], references: [id], onDelete: Cascade)
  user  User  @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([queueId, userId])
}

model Match {
  id         String   @id @default(cuid())
  queueId    String
  guildId    String
  mapPool    String? // maps separadas por vírgula
  currentMap String?
  sideChoice String? // CT ou TR
  status     String   @default("lobby") // lobby, veto, live, finished
  createdAt  DateTime @default(now())
  updatedAt  DateTime @updatedAt

  queue    Queue       @relation(fields: [queueId], references: [id], onDelete: Cascade)
  teams    MatchTeam[]
  vetoBans VetoBan[]
}

model MatchTeam {
  id       String @id @default(cuid())
  matchId  String
  teamName String // "Team A" ou "Team B"
  userId   String

  match Match @relation(fields: [matchId], references: [id], onDelete: Cascade)
  user  User  @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([matchId, userId])
}

model VetoBan {
  id       String @id @default(cuid())
  matchId  String
  map      String
  bannedBy String // "Team A" ou "Team B"
  order    Int

  match Match @relation(fields: [matchId], references: [id], onDelete: Cascade)

  @@unique([matchId, map])
}

model MapPool {
  id      String   @id @default(cuid())
  guildId String
  map     String
  addedAt DateTime @default(now())

  @@unique([guildId, map])
}
